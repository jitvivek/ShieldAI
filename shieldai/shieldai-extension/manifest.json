{
  "manifest_version": 3,
  "name": "ShieldAI Guard — AI Safety for India",
  "version": "1.0.0",
  "description": "Protect yourself and your family from harmful AI interactions. Detects prompt injection in Hindi, Hinglish, Tamil & English. Blocks Aadhaar, PAN, UPI leakage.",
  "permissions": ["storage", "notifications", "activeTab", "alarms"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://copilot.microsoft.com/*",
    "https://www.perplexity.ai/*",
    "https://huggingface.co/chat/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "https://www.perplexity.ai/*",
        "https://huggingface.co/chat/*"
      ],
      "js": ["src/content/index.ts"],
      "css": ["src/content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}

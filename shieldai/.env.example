# ============================================
# ShieldAI Environment Configuration
# Copy to .env and fill in values
# ============================================

# --- Node.js API ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL ---
DATABASE_URL=postgresql://shield:shield@postgres:5432/shieldai

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- ML Sidecar Service ---
ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_TIMEOUT_MS=500

# --- Rate Limiting ---
RATE_LIMIT_FREE_PER_MINUTE=100
RATE_LIMIT_FREE_PER_DAY=1000
RATE_LIMIT_PAID_PER_MINUTE=1000

# --- Detection Thresholds ---
THRESHOLD_SAFE=0.3
THRESHOLD_SUSPICIOUS=0.7

# --- API Key Settings ---
API_KEY_CACHE_TTL_SECONDS=300

# --- Dashboard ---
VITE_API_URL=http://localhost:3000

# --- ML Service ---
MODEL_CACHE_DIR=/app/models
DEVICE=cpu

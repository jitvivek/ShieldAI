# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://shield:shield@localhost:5432/shieldai

# Redis
REDIS_URL=redis://localhost:6379

# ShieldAI API (main detection engine)
SHIELDAI_API_URL=http://localhost:3000
SHIELDAI_API_KEY=your-internal-api-key

# Microsoft Teams
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Azure AD (for admin dashboard auth)
AZURE_AD_TENANT_ID=your-azure-tenant-id
AZURE_AD_CLIENT_ID=your-azure-client-id

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# ShieldAI Family API Configuration
SHIELDAI_API_URL=https://api.shieldai.dev
SHIELDAI_API_KEY=your_api_key_here

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=shieldai-family.firebaseapp.com
FIREBASE_PROJECT_ID=shieldai-family
FIREBASE_STORAGE_BUCKET=shieldai-family.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:android:abcdef

# Razorpay (Indian Payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Twilio (WhatsApp + SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# Backend Sync API
BACKEND_API_URL=https://family-api.shieldai.dev
BACKEND_WS_URL=wss://family-api.shieldai.dev/ws

# PostHog Analytics (privacy-first)
POSTHOG_API_KEY=phc_xxxxxxxxxx
POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking
SENTRY_DSN=https://xxxxxxxxxx@sentry.io/0000000

# Environment
NODE_ENV=development
